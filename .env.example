# Environment Variables

# API Configuration
VITE_API_URL=http://localhost:5000/api

# Authentication
VITE_AUTH_PROVIDER=firebase  # or 'custom'
VITE_AUTH_DOMAIN=your-auth-domain.com

# Analytics
VITE_ANALYTICS_ID=your-google-analytics-id

# Feature Flags
VITE_ENABLE_DRAG_DROP=true
VITE_ENABLE_SEMANTIC_GRAPH=true
VITE_ENABLE_ACHIEVEMENTS=false

# Debug Mode
VITE_DEBUG=false
